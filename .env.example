# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── Alpaca (Paper Trading Sandbox) ───
# Sign up: https://app.alpaca.markets/signup → Dashboard → Paper Trading → API Keys
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─── Finnhub ───
# Sign up: https://finnhub.io/register → Dashboard → copy API key
FINNHUB_API_KEY=your_finnhub_api_key_here

# ─── Tracked Symbols ───
EQUITY_SYMBOLS=AAPL,NVDA
CRYPTO_SYMBOLS=BTC

# ─── Polling Intervals (seconds) ───
FINNHUB_POLL_INTERVAL=15
YAHOO_POLL_INTERVAL=600
